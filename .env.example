# Ogen Complex Environment Variables
# Copy this file to .env and fill in values

# Vault signing secret — REQUIRED for production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, a random secret is generated per server restart (receipts won't verify across restarts)
VAULT_SECRET=

# Server port (default: 3000)
PORT=3000

{
  "rules": [
    {
      "rule_name": "high_temperature",
      "condition_json": "{\"temperature\":{\"gt\":85}}",
      "action_text": "High temperature detected. Check cooling system.",
      "priority": 10,
      "category": "thermal",
      "evidence_source": null
    },
    {
      "rule_name": "critical_temperature",
      "condition_json": "{\"temperature\":{\"gte\":105}}",
      "action_text": "CRITICAL: Shutdown recommended. Immediate inspection required.",
      "priority": 100,
      "category": "thermal",
      "evidence_source": "manuals/thermal_emergency.pdf"
    },
    {
      "rule_name": "nominal_pressure_band",
      "condition_json": "{\"pressure\":{\"between\":[95,125]}}",
      "action_text": "Pressure is within nominal operating band.",
      "priority": 1,
      "category": "mechanical",
      "evidence_source": null
    },
    {
      "rule_name": "high_pressure",
      "condition_json": "{\"pressure\":{\"gt\":130}}",
      "action_text": "Pressure exceeds normal range. Inspect seals and relief valves.",
      "priority": 10,
      "category": "mechanical",
      "evidence_source": null
    },
    {
      "rule_name": "low_fuel",
      "condition_json": "{\"fuel_level\":{\"lte\":10}}",
      "action_text": "Low fuel. Plan refueling soon.",
      "priority": 10,
      "category": "logistics",
      "evidence_source": null
    },
    {
      "rule_name": "critical_fuel",
      "condition_json": "{\"fuel_level\":{\"lt\":3}}",
      "action_text": "CRITICAL FUEL LEVEL. Immediate refuel required.",
      "priority": 100,
      "category": "logistics",
      "evidence_source": null
    },
    {
      "rule_name": "mission_mode_restricted",
      "condition_json": "{\"mode\":{\"in\":[\"restricted\",\"manual_override_required\"]}}",
      "action_text": "Restricted mission mode. Operator approval required.",
      "priority": 50,
      "category": "operations",
      "evidence_source": "manuals/operator_policy_v1.pdf"
    },
    {
      "rule_name": "engine_fire_detected",
      "condition_json": "{\"fire_detected\":{\"eq\":true}}",
      "action_text": "ENGINE FIRE. Execute suppression procedure immediately.",
      "priority": 100,
      "category": "emergency",
      "evidence_source": "manuals/engine_fire.pdf"
    },
    {
      "rule_name": "sensor_status_not_ok",
      "condition_json": "{\"sensor_status\":{\"ne\":\"ok\"}}",
      "action_text": "Sensor status is degraded. Switch to redundant sensing and preserve evidence.",
      "priority": 35,
      "category": "perception",
      "evidence_source": "manuals/perception_policy_v1.pdf"
    },
    {
      "rule_name": "fire_heat_smoke_combo",
      "condition_json": "{\"all\":[{\"temperature\":{\"gt\":80}},{\"smoke\":{\"eq\":true}}]}",
      "action_text": "Heat and smoke detected together. Treat as confirmed fire.",
      "priority": 100,
      "category": "fire",
      "evidence_source": "manuals/thermal_emergency.pdf"
    },
    {
      "rule_name": "chemical_ph_out_of_range",
      "condition_json": "{\"any\":[{\"ph\":{\"lt\":6.5}},{\"ph\":{\"gt\":8.5}}]}",
      "action_text": "pH is outside safe operating range.",
      "priority": 65,
      "category": "chemical",
      "evidence_source": null
    }
  ]
}
